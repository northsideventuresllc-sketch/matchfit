{
  "name": "match-fit-app",
  "version": "1.0.0-beta.1",
  "private": true,
  "engines": {
    "node": ">=20.19.0 <23"
  },
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "test": "vitest run",
    "db:push": "prisma generate && prisma db push",
    "generate": "prisma generate",
    "beta:setup": "node scripts/beta-launch-setup.mjs --db-push",
    "beta:preflight": "node --env-file=.env scripts/beta-launch-setup.mjs --preflight",
    "beta:preflight:production": "node --env-file=.env scripts/beta-launch-setup.mjs --preflight --production",
    "beta:vercel-env": "node scripts/vercel-env-push-beta.mjs",
    "db:locks": "sh scripts/show-sqlite-db-locks.sh",
    "test:watch": "vitest",
    "seed:dashboard-demo": "tsx --env-file=.env scripts/seed-demo-client-dashboard-showcase.js",
    "seed:admin": "tsx --env-file=.env scripts/seed-bootstrap-admin.js",
    "tos:alignment": "tsx scripts/tos-alignment-check.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.2.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jose": "^6.2.2",
    "next": "16.2.4",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "server-only": "^0.0.1",
    "stripe": "^22.0.2",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
