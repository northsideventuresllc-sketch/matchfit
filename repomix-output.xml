  attributionStripePaymentIntentId String?

  rescheduleRequests SessionRescheduleRequest[]
  payoutDisputes     SessionPayoutDispute[]

  /// Client Gate A closed (confirm, auto-silence, or revoke handled separately).
  gateASatisfiedAt DateTime?
  /// CLIENT_CONFIRM | AUTO_SILENCE
  gateASource          String?
  gateARevokedBeforeStartAt DateTime?

  /// Trainer Gate B — manual only; payout stays on file until set.
  trainerGateBCompletedAt DateTime?

  /// Starts after BOTH gates close: max(gate A, gate B) + 48h dispute buffer.
  payoutBufferEndsAt DateTime?
  payoutFundsFrozen  Boolean @default(false)

  /// Billing units consumed by this session (1 for per-session; fractional hours for per_hour).
  sessionConsumedUnits Float @default(1)

  /// Net add-on ledger slice attributed to this booking (see transaction ledger).
  allocatedNetAddonCents Int @default(0)

  disputeOpenedAt DateTime?

  /// Set when marketplace cron evaluated punch-in compliance for this session (idempotent miss counter).
  punchMissEvaluatedAt DateTime?

  punchIns SessionTrainerPunchIn[]
  trainerBusinessMileageEntries TrainerBusinessMileageEntry[]

  @@index([status, confirmationDeadlineAt])
  @@index([trainerId, clientId])
  @@index([trainerId, scheduledStartAt])
  @@index([conversationId])
  @@map("booked_training_sessions")
  @@schema("public")
}

/// Trainer geolocation snapshot at session start (SESSION STARTED). One row per booking.
model SessionTrainerPunchIn {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  bookedTrainingSessionId String                 @unique
  bookedTrainingSession   BookedTrainingSession @relation(fields: [bookedTrainingSessionId], references: [id], onDelete: Cascade)
  trainerId               String
  trainer                 Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  latitude        Float
  longitude       Float
  accuracyMeters  Float?
  /// WEB_GEOLOCATION | …
  source String @default("WEB_GEOLOCATION")

  @@index([trainerId, createdAt])
  @@map("session_trainer_punch_ins")
  @@schema("public")
}

/// Post–Gate A client dispute: freezes payout until admin resolves.
model SessionPayoutDispute {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookedTrainingSessionId String
  bookedTrainingSession   BookedTrainingSession @relation(fields: [bookedTrainingSessionId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  answeredWasRescheduled Boolean
  answeredWasCancelled   Boolean
  answeredReasonDetail   String

  /// PENDING_ADMIN | RESOLVED
  status String @default("PENDING_ADMIN")

  @@index([status])
  @@index([bookedTrainingSessionId])
  @@map("session_payout_disputes")
  @@schema("public")
}

/// One session at a time: propose new start/end; counterparty accepts or declines (policy-driven refunds).
model SessionRescheduleRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookedTrainingSessionId String
  bookedTrainingSession   BookedTrainingSession @relation(fields: [bookedTrainingSessionId], references: [id], onDelete: Cascade)

  requestedByTrainer Boolean

  proposedStartAt DateTime
  proposedEndAt   DateTime
  note            String?

  /// PENDING | ACCEPTED | DECLINED | WITHDRAWN
  status String @default("PENDING")

  @@index([bookedTrainingSessionId])
  @@index([status])
  @@map("session_reschedule_requests")
  @@schema("public")
}

/// Trainer requests cancellation of an entire purchased package; staff reviews payout (see admin tools).
model TrainerPackageCancellationRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversationId String
  conversation   TrainerClientConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  trainerId      String
  trainer        Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  reason String

  /// PENDING_REVIEW | APPROVED | REJECTED
  status String @default("PENDING_REVIEW")

  adminDecisionNotes String?

  @@index([status])
  @@index([trainerId])
  @@map("trainer_package_cancellation_requests")
  @@schema("public")
}

/// DIY first-delivery SLA (5 business days from engagement start).
model DiyPlanEngagement {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainerId String
  trainer   Trainer @relation("DiyEngagementTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client @relation("DiyEngagementClient", fields: [clientId], references: [id], onDelete: Cascade)

  engagementStartedAt DateTime
  firstDeliverByAt    DateTime
  firstDeliveredAt    DateTime?

  /// PENDING_DELIVERY | DELIVERED | MISSED | REFUND_ALERT_SENT
  status String @default("PENDING_DELIVERY")

  /// Confirmation of receivables: trainer logs first deliverable (mirror of SLA delivery when applicable).
  trainerReceivableLoggedAt DateTime?
  clientReceivableAcknowledgedAt DateTime?
  /// Payout-cycle hold: earliest time funds may release after payment + 14d (effective after handshake).
  cycleFundsReleaseNotBeforeAt DateTime?

  /// Calendar deadline (typically payment / engagement start + 14 days) for first DIY deliverable logging.
  wallClockDeliverableDueAt DateTime?
  /// After wall-clock deadline without deliverable: client login attestation (YES_MARK_DONE | NO_NOT_RECEIVED).
  clientPostDueAttestation   String?
  clientPostDueAttestedAt    DateTime?
  /// When client attests NO: trainer must upload within 24h or request extension.
  trainerUrgentUploadDeadlineAt DateTime?

  extensionHoursRequested      Float?
  extensionRequestedAt         DateTime?
  extensionClientDecisionByAt DateTime?
  /// PENDING | APPROVED | DECLINED | AUTO_APPROVED
  extensionStatus            String?
  extendedDeliverableDueAt   DateTime?

  sourceServiceTransactionId String?
  sourceServiceTransaction   TrainerClientServiceTransaction? @relation(fields: [sourceServiceTransactionId], references: [id], onDelete: SetNull)

  @@unique([sourceServiceTransactionId])
  @@index([status, firstDeliverByAt])
  @@index([trainerId, clientId])
  @@map("diy_plan_engagements")
  @@schema("public")
}

/// A block is bidirectional for product purposes but stored from the initiator’s perspective.
model UserBlock {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  blockerIsTrainer Boolean
  blockerId        String
  blockedIsTrainer Boolean
  blockedId        String

  reasonCategory String?
  reasonDetails  String?

  /// Client→trainer or mirrored on trainer→client: exclude this trainer from the client’s match browse decks.
  hideTrainerFromClientMatchFeed Boolean @default(true)
  /// Client→trainer or mirrored: hide this trainer’s FitHub posts from the client’s feed.
  hideTrainerFromClientFithub Boolean @default(true)
  /// Trainer→client: exclude this client from the trainer’s discover-clients list.
  hideClientFromTrainerDiscover Boolean @default(true)
  /// Trainer→trainer: viewer (blocker) does not see blocked coach’s posts in the trainer FitHub feed.
  hideBlockedTrainerFromViewerTrainerFithub Boolean @default(false)
  /// When true, DMs and related APIs treat the pair as non-contactable until lifted.
  blockDirectChat Boolean @default(true)

  @@unique([blockerIsTrainer, blockerId, blockedIsTrainer, blockedId])
  @@index([blockedIsTrainer, blockedId])
  @@map("user_blocks")
  @@schema("public")
}

model SafetyReport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  reporterIsTrainer Boolean
  reporterId        String

  subjectIsTrainer Boolean
  subjectId        String

  category String
  details  String

  /// PENDING | CLOSED
  status String @default("PENDING")

  suspensionRecords SuspensionRecord[]

  @@index([subjectIsTrainer, subjectId, createdAt])
  @@index([status, createdAt])
  @@map("safety_reports")
  @@schema("public")
}

/// Compliance / audit copy for account suspensions. Housekeeping purges via `purgeAfter` after lift.
/// Product-facing fields: `id`, `reason`, optional `expiresAt` (row also links `SafetyReport` and subject).
model SuspensionRecord {
  id        String   @id @default(cuid())
  reason    String?
  expiresAt DateTime?

  createdAt DateTime @default(now())

  subjectIsTrainer Boolean
  subjectId        String

  reportId String?
  report   SafetyReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  liftedAt DateTime?
  /// After lift: `liftedAt + 5 years`. Rows with `liftedAt` set and `purgeAfter` in the past may be deleted.
  purgeAfter DateTime

  @@index([purgeAfter])
  @@index([subjectIsTrainer, subjectId])
  @@map("suspension_records")
  @@schema("public")
}

/// Premium trainers enter a daily random draw (weighted tickets) for the public home “featured” carousel.
/// `displayDayKey` is the America/New_York calendar date when winners are shown (bidding/entries close at midnight Eastern at the start of that date).
model FeaturedRaffleEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  /// First three digits of the trainer’s in-person US ZIP from the Onboarding Questionnaire (regional pool).
  regionZipPrefix String
  displayDayKey   String
  /// Each entrant contributes this many tickets in the weighted draw (product default: 5).
  ticketWeight Int @default(5)

  @@unique([trainerId, regionZipPrefix, displayDayKey])
  @@index([regionZipPrefix, displayDayKey])
  @@map("featured_raffle_entries")
  @@schema("public")
}

/// Paid sponsored slots (top two bids per region per display day). Amounts are in USD cents; billing may be simulated until coach Stripe is connected.
model FeaturedPlacementBid {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  regionZipPrefix String
  displayDayKey   String
  /// Current committed bid total (non-refundable; increases when the trainer raises their bid).
  amountCents    Int
  /// Amount successfully collected toward this bid window (≤ amountCents when a card charge is partial / pending).
  paidCents      Int @default(0)
  rulesVersion   String?
  rulesAcceptedAt DateTime?

  @@unique([trainerId, regionZipPrefix, displayDayKey])
  @@index([regionZipPrefix, displayDayKey])
  @@map("featured_placement_bids")
  @@schema("public")
}

/// Materialized winners for a region + display day (resolved after the Eastern midnight cutoff).
model FeaturedDailyAllocation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  regionZipPrefix String
  displayDayKey   String

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  /// PAID_BID | RAFFLE
  source   String
  /// Lower sorts earlier in the carousel (paid bids first).
  sortOrder Int

  @@unique([regionZipPrefix, displayDayKey, trainerId])
  @@index([regionZipPrefix, displayDayKey, sortOrder])
  @@map("featured_daily_allocations")
  @@schema("public")
}

/// Cached trainer token balance (source of truth is `TrainerTokenLedgerEntry`; balance updated in the same DB transaction).
model TrainerTokenBalance {
  trainerId String  @id
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("trainer_token_balances")
  @@schema("public")
}

/// Immutable audit log for all trainer token movements.
model TrainerTokenLedgerEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  /// Signed delta applied to balance (credits positive, debits negative).
  delta Int

  /// WEEKLY_GRANT | SALE_REWARD | STRIPE_PURCHASE | CLIENT_GIFT | PROMOTION_SPEND | ADMIN_ADJUST | FIVE_STAR_REVIEW
  reason String

  /// Optional idempotency / linkage (e.g. Stripe session id, weekly grant key).
  referenceKey String?

  /// Optional JSON for debugging (pack counts, post id, etc.).
  metaJson String?

  @@index([trainerId, createdAt])
  @@index([trainerId, reason, referenceKey])
  @@map("trainer_token_ledger_entries")
  @@schema("public")
}

/// Time-bounded FitHub post boost paid with tokens (regional scoring in client feed).
model TrainerFitHubPostPromotion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   TrainerFitHubPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  /// Total tokens debited for this window (minimum 20 per scheduled day at creation).
  tokensSpent Int

  /// Chosen promotion length in whole days (≥ 1).
  durationDays Int

  /// First three digits of trainer in-person ZIP when promotion was created (drives regional boost).
  regionZipPrefix String

  startsAt DateTime
  endsAt   DateTime

  @@index([postId, startsAt, endsAt])
  @@index([trainerId, endsAt])
  @@map("trainer_fit_hub_post_promotions")
  @@schema("public")
}

/// Idempotent weekly free token drop for premium trainers (America/New_York ISO week key).
model TrainerWeeklyTokenGrant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  /// e.g. 2026-W17 (ISO week, America/New_York calendar date).
  weekKey String

  @@unique([trainerId, weekKey])
  @@map("trainer_weekly_token_grants")
  @@schema("public")
}

/// Completed paid service between client and trainer (drives sale-token rewards + chat tipping eligibility).
model TrainerClientServiceTransaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId String
  client   Client @relation("TrainerServiceTxClient", fields: [clientId], references: [id], onDelete: Cascade)
  trainerId String
  trainer   Trainer @relation("TrainerServiceTxTrainer", fields: [trainerId], references: [id], onDelete: Cascade)

  completedAt DateTime
  amountCents Int @default(0)

  /// STRIPE_CHECKOUT | STAFF_IMPORT
  source String @default("STRIPE_CHECKOUT")

  /// When set, duplicate Stripe events must not double-award sale tokens.
  stripeCheckoutSessionId String? @unique

  /// PaymentIntent on the Checkout Session (partial refunds use this id).
  stripePaymentIntentId String?

  /// Total amount the card was charged (coach subtotal + admin line item), in USD cents when known.
  totalChargedCents Int?

  /// Match Fit 20% administrative line item in cents when known (non-refundable).
  adminFeeCents Int?

  /// Optional dedupe key for staff imports or future non-Stripe flows.
  idempotencyKey String? @unique

  /// When sale-token reward was applied (idempotent).
  trainerSaleTokensGrantedAt DateTime?

  serviceId     String?
  billingUnit   String?
  /// Stripe / checkout label snapshot for receipts (e.g. tier title).
  purchaseLabelSnapshot String?
  /// Credits this checkout added toward bookable sessions (0 when unlimited purchase).
  sessionCreditsGranted        Int     @default(0)
  bookingUnlimitedPurchase     Boolean @default(false)

  /// When set, receipt/notifications for this row were delivered (idempotent with Stripe retries).
  purchaseSideEffectsAt DateTime?

  bookingsFromPurchase BookedTrainingSession[] @relation("BookingFromServiceTx")
  diyPlanEngagements   DiyPlanEngagement[]

  /// Gross card total (coach line + Match Fit admin line).
  ledgerGrossTotalCents Int?
  /// Estimated Stripe processing (non-refundable display + ledger).
  ledgerStripeFeeEstimateCents Int?
  ledgerNetAfterFeesCents     Int?

  ledgerNetServicePoolCents Int?
  ledgerNetAddonPoolCents     Int       @default(0)
  ledgerTotalServiceUnits     Int?
  ledgerTotalAddonUnits       Int       @default(0)
  ledgerPerServiceUnitNetCents Int?
  ledgerPerAddonUnitNetCents   Int       @default(0)

  /// SERVICE_UNIT | TIME_UNIT | CYCLE_DIY
  payoutModel String?

  @@index([clientId, trainerId, completedAt])
  @@index([stripePaymentIntentId])
  @@map("trainer_client_service_transactions")
  @@schema("public")
}

/// Trainer-logged business miles (manual entry or linked workflow) for tax estimates on Client Management.
model TrainerBusinessMileageEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  occurredAt DateTime
  miles      Float
  note       String?

  bookedTrainingSessionId String?
  bookedTrainingSession   BookedTrainingSession? @relation(fields: [bookedTrainingSessionId], references: [id], onDelete: SetNull)

  /// MANUAL | THIRD_PARTY_LINK
  source String @default("MANUAL")

  @@index([trainerId, occurredAt])
  @@map("trainer_business_mileage_entries")
  @@schema("public")
}

/// Trainer business expenses (tax-prep helpers on Client Management).
model TrainerBusinessExpense {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  spentAt   DateTime
  amountCents Int
  category  String
  description String?

  /// Heuristic flag for UI — not tax advice.
  likelyTaxDeductible Boolean @default(true)

  @@index([trainerId, spentAt])
  @@map("trainer_business_expenses")
  @@schema("public")
}

/// Private trainer notes + medical context for a client (trainer-only write; client sees non-medical subset via goals UI only).
model TrainerClientCoachingProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainerId String
  trainer   Trainer @relation("CoachingProfileTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client @relation("CoachingProfileClient", fields: [clientId], references: [id], onDelete: Cascade)

  generalNotes         String?
  medicalInjuryNotes   String?

  @@unique([trainerId, clientId])
  @@index([clientId])
  @@map("trainer_client_coaching_profiles")
  @@schema("public")
}

/// SHORT | LONG | GENERAL — goals visible to the client on Service Management when synced.
model TrainerClientGoal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainerId String
  trainer   Trainer @relation("GoalTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client @relation("GoalClient", fields: [clientId], references: [id], onDelete: Cascade)

  /// SHORT | LONG | GENERAL
  horizon              String
  goalText             String
  completionCriteria   String
  completedAt          DateTime?

  @@index([trainerId, clientId])
  @@index([clientId])
  @@map("trainer_client_goals")
  @@schema("public")
}

/// Trainer session diary entries; body emailed to client on request (masked From: trainer@matchfit.com when domain verified).
model TrainerClientSessionSummary {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainerId String
  trainer   Trainer @relation("SummaryTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client @relation("SummaryClient", fields: [clientId], references: [id], onDelete: Cascade)

  occurredAt DateTime
  body       String
  emailedAt  DateTime?

  @@index([trainerId, clientId, occurredAt])
  @@index([clientId])
  @@map("trainer_client_session_summaries")
  @@schema("public")
}

/// Client → trainer appreciation tokens (platform-minted to trainer). Capped per ISO week (NY) per pair for abuse control.
model ClientTrainerTokenGift {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  amount  Int
  weekKey String

  @@index([clientId, trainerId, weekKey])
  @@map("client_trainer_token_gifts")
  @@schema("public")
}

// Supabase GoTrue is `auth.*` — use the Supabase client or SQL, not Prisma.
// Do not list `auth` in `datasource.schemas` with `@@map` models to GoTrue tables:
// on Prisma 5, `@@ignore` does not exclude models from `db push`, so minimal stubs
// can try to alter `auth.identities`, `auth.schema_migrations`, etc.
// The Supabase template table `public.profiles` (FK → `auth.users`) forces `auth`
// into `schemas` and blocks public-only push; migration
// `20260509150000_drop_supabase_template_public_profiles` removes it if you still
// use that template. For `auth` in `schemas` without DDL on GoTrue, use Prisma
// 6.13+ externally managed tables (`prisma.config.ts`).
