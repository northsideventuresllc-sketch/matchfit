        trainerId,
        clientId: parsed.data.clientId,
        generalNotes: parsed.data.generalNotes ?? null,
        medicalInjuryNotes: parsed.data.medicalInjuryNotes ?? null,
      },
      update: {
        generalNotes: parsed.data.generalNotes ?? null,
        medicalInjuryNotes: parsed.data.medicalInjuryNotes ?? null,
      },
    });
    return NextResponse.json({ ok: true });
  } catch (e) {
