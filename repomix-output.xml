                          {hasS ? <span className="h-1.5 w-1.5 rounded-full bg-emerald-400" title="Extra opening" /> : null}
                          {hasB ? <span className="h-1.5 w-1.5 rounded-full bg-rose-400" title="Blackout" /> : null}
