};

function chip(text: string) {
  const t = text.trim();
  if (!t) return null;
  return (
    <span className="inline-flex items-center rounded-full border border-white/[0.1] bg-white/[0.05] px-3 py-1 text-xs font-semibold text-white/80">
      {t}
    </span>
  );
}

