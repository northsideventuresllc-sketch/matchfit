                        className={`min-h-[4.25rem] bg-[#0E1016] p-1.5 text-left transition hover:bg-white/[0.04] ${cell.inMonth ? "" : "opacity-40"} ${selected ? "ring-1 ring-inset ring-[#FF7E00]/55" : ""}`}
