      return NextResponse.json({ ok: true });
    }
    const r = await trainerSyncBookingVideoFromOAuth({
      trainerId,
      bookingId: id,
      provider: parsed.data.provider as VideoConferenceProviderKey,
    });
    if ("error" in r) {
      return NextResponse.json({ error: r.error }, { status: 400 });
