    showImagePosts: row.showImagePosts ?? true,
    showVideoPosts: row.showVideoPosts ?? true,
    autoplayVideo: row.autoplayVideo ?? false,
    hideRepeatedTrainers: row.hideRepeatedTrainers ?? false,
  };
}
