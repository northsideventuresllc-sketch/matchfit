        kind: n.kind,
        title: n.title,
        body: n.body,
        linkHref: n.linkHref,
        read: n.readAt != null,
        createdAt: n.createdAt.toISOString(),
        archivedAt: n.archivedAt?.toISOString() ?? null,
      })),
    });
  } catch (e) {
    console.error(e);
    return NextResponse.json({ error: "Could not load notifications." }, { status: 500 });
  }
