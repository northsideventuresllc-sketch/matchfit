const SETTINGS_QUICK_LINKS_HASH = "#trainer-quick-links-settings";

function QuickLinkIcon(props: { id: TrainerDashboardQuickLinkId; className?: string }) {
  const c = props.className ?? "h-8 w-8 sm:h-9 sm:w-9";
  switch (props.id) {
    case "fithub":
