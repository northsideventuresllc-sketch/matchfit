  }
  const access = typeof j?.access_token === "string" ? j.access_token : undefined;
  const expSec = typeof j?.expires_in === "number" ? j.expires_in : 3600;
  return {
    refreshToken: refresh,
    accessToken: access,
    expiresAtMs: Date.now() + Math.max(60, expSec) * 1000,
  };
}

