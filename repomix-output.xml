SELECT
    lower(hex(randomblob(16))),
    datetime('now'),
    datetime('now'),
    "id",
    "twoFactorMethod",
    CASE WHEN "twoFactorMethod" = 'EMAIL' THEN "email" ELSE NULL END,
    CASE WHEN "twoFactorMethod" IN ('SMS', 'VOICE') THEN "phone" ELSE NULL END,
    1,
    NULL,
    NULL,
    1
