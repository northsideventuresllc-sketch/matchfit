function escapeHtml(s: string): string {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

export async function sendAdministratorSignupReviewEmail(opts: {
  pendingId: string;
  firstName: string;
  lastName: string;
  dateOfBirth: string;
  email: string;
  origin: string;
}): Promise<void> {
