generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  /// Only `public` here so `db push` / Migrate never touch Supabase GoTrue (`auth.*`).
  /// `@@ignore` does not exclude models from `db push` on Prisma 5 — stub `@@map`
  /// models to `auth.users` / `auth.identities` / … caused destructive diffs.
  /// To list `auth` again without DDL on GoTrue tables, upgrade to Prisma 6.13+
  /// and declare those tables as externally managed in `prisma.config.ts`.
  schemas   = ["public"]
  /// Pooled URL for the app runtime (Supabase pooler / PgBouncer).
  url       = env("DATABASE_URL")
  /// Direct Postgres URL for migrations and `db push` (bypasses pooler; required for DDL on Supabase).
  directUrl = env("DIRECT_URL")
}

/// Internal Match Fit staff administrator (separate from client/trainer accounts).
model Administrator {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Eight-character staff code (letters + digits), unique login identifier.
  adminCode    String @unique
  email        String @unique
  passwordHash String
  firstName    String
  lastName     String
  /// ISO date string YYYY-MM-DD (birth date; used to derive admin code at onboarding).
  dateOfBirth  String

  @@map("administrators")
  @@schema("public")
}

/// Prospective administrator awaiting approval email action (creates {@link Administrator} when approved).
model PendingAdministratorRegistration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  firstName    String
  lastName     String
  dateOfBirth  String
  email        String
  passwordHash String

  /// PENDING | DENIED (approved rows are deleted after account creation)
  status String @default("PENDING")

  @@index([email])
  @@map("pending_administrator_registrations")
  @@schema("public")
}

model Client {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName       String
  lastName        String
  preferredName   String
  username        String           @unique
  phone           String
  email           String           @unique
  passwordHash    String
  zipCode         String
  dateOfBirth     String
  termsAcceptedAt DateTime
  /// When the user accepted the posted Privacy Policy (aligned with terms at sign-up / checkout).
  privacyPolicyAcceptedAt DateTime?
  twoFactorEnabled Boolean @default(false)
  /// Last-used delivery channel (EMAIL | SMS | VOICE | NONE); mirrors default `ClientTwoFactorChannel` for login.
  twoFactorMethod String @default("NONE")

  /// Transient login 2FA only: HMAC of the 6-digit code sent after password check (never plaintext). Cleared after verify or cancel. Channel enrollment uses `ClientTwoFactorChannel.verifyOtpHash` instead — see model docs below.
  twoFactorOtpHash    String?
  twoFactorOtpExpires DateTime?
  /// Wrong-code attempts during login 2FA; reset when a new code is issued or verification succeeds.
  twoFactorLoginAttempts Int @default(0)

  /// When true, session cookies use a longer lifetime; when false, shorter (see session helpers).
  stayLoggedIn Boolean @default(true)

  /// One-time nonce for email password-reset link (paired with signed JWT).
  passwordChangeNonce    String?
  passwordChangeExpires  DateTime?
  passwordChangeOtpHash  String?
  passwordChangeOtpExpires DateTime?

  stripeCustomerId     String?
  stripeSubscriptionId String?
  /// Mirrors Stripe subscription status for dashboard access control.
  stripeSubscriptionActive Boolean @default(false)
  /// When subscription is inactive and `now` is after this instant, non-billing dashboard routes require renewal (null = no lock).
  subscriptionGraceUntil DateTime?
  /// Set from Stripe `invoice.payment_succeeded` (and initial signup) for analytics / “recently paid” windows.
  stripeLastSubscriptionInvoicePaidAt DateTime?

  /// Short public-style bio; never expose private address to trainer APIs.
  bio String?

  /// Relative URL served from `public/` (e.g. `/uploads/clients/...`).
  profileImageUrl String?

  /// Private mailing address — owner-only APIs; must never be selected for trainer/public profiles.
  addressLine1   String?
  addressLine2   String?
  addressCity    String?
  addressState   String?
  addressPostal  String?
  addressCountry String?

  /// Last time username was changed (null = never changed since signup).
  usernameChangedAt DateTime?

  /// Email change: link sent to `pendingEmail`; paired with signed JWT + `emailChangeNonce`.
  pendingEmail       String?
  emailChangeNonce   String?
  emailChangeExpires DateTime?

  /// Phone change: OTP sent to new number (or to current email as fallback); `pendingPhone` until confirmed.
  pendingPhone           String?
  phoneChangeOtpHash     String?
  phoneChangeOtpExpires DateTime?
  lastPhoneChangeRequest DateTime?
  lastEmailChangeRequest DateTime?

  twoFactorChannels ClientTwoFactorChannel[]

  /// JSON document: goals, service types, delivery modes, niche interests (see `lib/client-match-preferences.ts`).
  matchPreferencesJson          String?
  matchPreferencesCompletedAt   DateTime?
  /// When true, published client profile can be discovered by trainers who may send a nudge.
  allowTrainerDiscovery Boolean @default(true)

  trainerNudges   TrainerClientNudge[]
  savedTrainers   ClientSavedTrainer[]
  /// Swipe-left on Find Trainers: excluded from swipe deck but still listed in scroll (until matched).
  trainerBrowsePasses ClientTrainerBrowsePass[]
  /// Trainer-initiated unmatch: hidden from this trainer’s discovery deck for 90 days.
  trainerDiscoverPasses TrainerClientBrowsePass[]
  conversations   TrainerClientConversation[]

  safetySuspended   Boolean   @default(false)
  safetySuspendedAt DateTime?

  /// JSON: per-category push toggles (see `lib/client-notification-prefs.ts`).
  notificationPrefsJson String?

  /// Browser Web Push subscriptions (VAPID); see `lib/web-push-send.ts`.
  webPushSubscriptions WebPushSubscription[]

  /// JSON: FitHub feed & social viewing preferences (see `lib/client-fithub-prefs.ts`).
  fitHubPrefsJson String?

  notifications ClientNotification[]

  fitHubPostLikes    TrainerFitHubPostLike[]
  fitHubComments     TrainerFitHubComment[]
  fitHubReposts      ClientFitHubRepost[]
  fitHubPostReports  TrainerFitHubPostReport[]
  fitHubPostShares   ClientFitHubPostShare[]

  /// JSON: rolling algorithm context built from daily questionnaire answers (see `lib/client-daily-questionnaire.ts`).
  dailyAlgorithmContextJson String?

  dailyQuestionnaires ClientDailyQuestionnaire[]
  bugReports         ClientBugReport[]
  productIdeaSubmissions ProductIdeaSubmission[]

  internalQaDailyCursor InternalQaClientDailyCursor?

  serviceTransactions TrainerClientServiceTransaction[] @relation("TrainerServiceTxClient")
  trainerTokenGifts     ClientTrainerTokenGift[]

  bookedSessionsClient BookedTrainingSession[] @relation("BookedSessionClient")
  diyEngagementsClient DiyPlanEngagement[]     @relation("DiyEngagementClient")
  trainerPackageCancellationRequests TrainerPackageCancellationRequest[]
  sessionPayoutDisputes               SessionPayoutDispute[]

  /// Client-authored star reviews + optional testimonials for trainers they worked with.
  clientTrainerReviews ClientTrainerReview[]

  trainerCoachingProfilesAsClient TrainerClientCoachingProfile[] @relation("CoachingProfileClient")
  trainerGoalsForClient           TrainerClientGoal[]            @relation("GoalClient")
  trainerSessionSummariesForClient TrainerClientSessionSummary[] @relation("SummaryClient")

  /// JSON toggles for optional public-profile fields (see `lib/optional-profile-visibility.ts`).
  optionalProfileVisibilityJson String?
  /// Set when the user deletes their account; row retained for FKs / safety records with PII scrubbed.
  deidentifiedAt DateTime?

  /// Internal QA only: synthetic persona rows used for Match Fit owner sandbox (never visible to real users).
  internalQaSyntheticPersona Boolean @default(false)

  /// JSON array of quick-link ids for the client dashboard home card (see `lib/client-dashboard-quick-links.ts`).
  dashboardQuickLinkIdsJson String?

  @@map("clients")
  @@schema("public")
}

/// End-user browser push subscription (Web Push + VAPID). Exactly one of clientId / trainerId is set.
model WebPushSubscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  endpoint String @unique
  p256dh   String
  auth     String

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  trainerId String?
  trainer   Trainer? @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  userAgent String?

  @@index([clientId])
  @@index([trainerId])
  @@map("web_push_subscriptions")
  @@schema("public")
}

/// Destinations for sign-in 2FA (email only at runtime; legacy rows may still read SMS | VOICE until migrated).
/// - **Enrolling a new destination:** `verifyOtpHash` / `verifyOtpExpires` store the 6-digit proof-of-ownership code (see settings 2FA API).
/// - **Signing in:** the live code lives on `Client.twoFactorOtpHash` (single active login challenge), not on this row.
model ClientTwoFactorChannel {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  /// EMAIL | SMS | VOICE
  delivery String
  email    String?
  phone    String?

  verified Boolean @default(false)

  /// 6-digit enrollment code (hashed) until `verified` becomes true; separate from login OTP on `Client`.
  verifyOtpHash    String?
  verifyOtpExpires DateTime?

  lastCode    String?
  expiresAt   DateTime?

  /// Set when the user taps “Resend code” (login initial send clears this). Used only for the 60s resend throttle.
  lastEmailResendAt DateTime?

  /// Which channel receives login 2FA codes (exactly one verified default per client when 2FA is on).
  isDefaultLogin Boolean @default(false)

  @@index([clientId])
  @@map("client_two_factor_channels")
  @@schema("public")
}

/// Pre-payment registration only. Deleted after successful billing or when expired / abandoned.
model PendingClientRegistration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  expiresAt DateTime

  firstName       String
  lastName        String
  preferredName   String
  username        String
  phone           String
  email           String
  passwordHash    String
  zipCode         String
  dateOfBirth     String
  termsAcceptedAt DateTime
  privacyPolicyAcceptedAt DateTime?

  /// PENDING_2FA | AWAITING_PAYMENT
  status              String    @default("PENDING_2FA")
  twoFactorEnabled    Boolean   @default(false)
  /// NONE | EMAIL | SMS | VOICE
  twoFactorMethod     String
  otpHash             String?
  otpExpiresAt        DateTime?

  stayLoggedIn Boolean @default(true)

  stripeCustomerId    String?
  stripeSubscriptionId String?

  @@index([email])
  @@index([username])
  @@map("pending_client_registrations")
  @@schema("public")
}

model Trainer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName String
  lastName  String
  username  String @unique
  phone     String
  email     String @unique
  passwordHash String
  bio       String?

  preferredName      String?
  pronouns           String?
  ethnicity          String?
  languagesSpoken    String?
  fitnessNiches      String?
  yearsCoaching      String?
  genderIdentity     String?
  profileImageUrl    String?
  socialInstagram    String?
  socialTiktok       String?
  socialFacebook     String?
  socialLinkedin     String?
  socialOtherUrl     String?

  termsAcceptedAt DateTime
  privacyPolicyAcceptedAt DateTime?

  twoFactorEnabled Boolean @default(false)
  /// Last-used delivery channel (EMAIL | SMS | VOICE | NONE).
  twoFactorMethod String @default("NONE")

  twoFactorOtpHash       String?
  twoFactorOtpExpires    DateTime?
  twoFactorLoginAttempts Int      @default(0)

  stayLoggedIn Boolean @default(true)

  passwordChangeNonce      String?
  passwordChangeExpires    DateTime?
  passwordChangeOtpHash    String?
  passwordChangeOtpExpires DateTime?

  optionalProfileVisibilityJson String?
  deidentifiedAt DateTime?

  profile           TrainerProfile?
  twoFactorChannels TrainerTwoFactorChannel[]

  clientNudges    TrainerClientNudge[]
  savedByClients  ClientSavedTrainer[]
  clientBrowsePasses ClientTrainerBrowsePass[]
  /// Trainer passed / unmatched this client in discovery (90-day cooldown).
  trainerDiscoverPasses TrainerClientBrowsePass[]
  conversations   TrainerClientConversation[]
  discoverMatchBatches TrainerDiscoverMatchBatch[]

  fitHubPosts TrainerFitHubPost[]

  /// JSON: per-category push toggles (see `lib/trainer-notification-prefs.ts`).
  notificationPrefsJson String?

  webPushSubscriptions WebPushSubscription[]

  notifications TrainerNotification[]

  safetySuspended   Boolean   @default(false)
  safetySuspendedAt DateTime?

  /// Internal QA only: synthetic persona rows for trainer-owner sandbox (never visible to real users).
  internalQaSyntheticPersona Boolean @default(false)

  featuredRaffleEntries   FeaturedRaffleEntry[]
  featuredPlacementBids   FeaturedPlacementBid[]
  featuredDailyAllocations FeaturedDailyAllocation[]

  tokenBalance              TrainerTokenBalance?
  tokenLedgerEntries        TrainerTokenLedgerEntry[]
  fitHubPostPromotions      TrainerFitHubPostPromotion[]
  weeklyTokenGrants         TrainerWeeklyTokenGrant[]
  clientServiceTransactions TrainerClientServiceTransaction[] @relation("TrainerServiceTxTrainer")
  tokenGiftsReceived        ClientTrainerTokenGift[]

  bookedSessionsTrainer BookedTrainingSession[] @relation("BookedSessionTrainer")
  diyEngagementsTrainer DiyPlanEngagement[]     @relation("DiyEngagementTrainer")
  sessionTrainerPunchIns SessionTrainerPunchIn[]
  trainerPackageCancellationRequests TrainerPackageCancellationRequest[]

  businessMileageEntries TrainerBusinessMileageEntry[]
  businessExpenses      TrainerBusinessExpense[]

  coachingProfiles TrainerClientCoachingProfile[] @relation("CoachingProfileTrainer")
  clientGoalsAuthored TrainerClientGoal[]         @relation("GoalTrainer")
  sessionSummariesAuthored TrainerClientSessionSummary[] @relation("SummaryTrainer")

  clientTrainerReviews ClientTrainerReview[]

  /// OAuth-linked accounts used to create Meet / Zoom / Teams links for paid clients’ bookings.
  videoConferenceConnections TrainerVideoConferenceConnection[]

  productIdeaSubmissions ProductIdeaSubmission[]

  internalQaDailyCursor InternalQaTrainerDailyCursor?

  @@map("trainers")
  @@schema("public")
}

/// A trainer tapped “Nudge” on a client’s public profile to start a conversation.
model TrainerClientNudge {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  message String?
  readAt  DateTime?

  @@index([clientId, createdAt])
  @@index([trainerId])
  @@map("trainer_client_nudges")
  @@schema("public")
}

/// One generated set of 3 daily matching questions per client. Incomplete instances expire after 72h (archived).
/// After completion, a 24h cooldown applies before the next questionnaire is created.
model ClientDailyQuestionnaire {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  /// Start of the window for this questionnaire instance.
  windowStartedAt DateTime

  /// JSON: three individualized questions (see `lib/client-daily-questionnaire.ts`).
  questionsJson String

  /// JSON: map of question id -> answer payload (strings).
  answersJson String?

  completedAt DateTime?

  /// Set when an incomplete questionnaire is superseded (e.g. after 72h without submit).
  archivedAt DateTime?

  @@index([clientId, windowStartedAt])
  @@index([clientId, archivedAt, completedAt])
  @@map("client_daily_questionnaires")
  @@schema("public")
}

/// Product issues/feedback reports (from dashboard or public report page).
model ClientBugReport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  anonymous   Boolean @default(false)
  reporterName String?
  reporterEmail String?
  category    String
  description String

  @@index([clientId, createdAt])
  @@map("client_bug_reports")
  @@schema("public")
}

/// Product improvement ideas from clients, trainers, or anonymous visitors.
model ProductIdeaSubmission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  trainerId String?
  trainer   Trainer? @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  anonymous     Boolean @default(false)
  reporterName  String?
  reporterEmail String?
  category      String
  description   String

  @@index([clientId, createdAt])
  @@index([trainerId, createdAt])
  @@map("product_idea_submissions")
  @@schema("public")
}

/// In-app notification feed (nudges, matches, billing, product updates).
model ClientNotification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  /// NUDGE | NEW_MATCH | DAILY_QUESTIONNAIRE | APP_UPDATE | BILLING | SYSTEM
  kind    String
  title   String
  body    String
  linkHref String?
  readAt  DateTime?

  /// Set when the client archives or when the inbox auto-archives (30 days after createdAt).
  archivedAt DateTime?

  @@index([clientId, createdAt])
  @@index([clientId, archivedAt])
  @@map("client_notifications")
  @@schema("public")
}

/// Trainer-authored social post for the client FitHub feed.
model TrainerFitHubPost {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  /// TEXT | IMAGE | VIDEO | CAROUSEL
  postType String
  caption  String?
  bodyText String?
  mediaUrl String?

  /// When set in the future, the post stays hidden from public FitHub until this time.
  scheduledPublishAt DateTime?
  /// PUBLIC | PRIVATE — private posts are only visible to the author in Premium MY CONTENT.
  visibility String @default("PUBLIC")
  /// JSON string array of normalized hashtag tokens (no #, lowercase).
  hashtagsJson String?
  /// JSON string array of image/video URLs for CAROUSEL posts (2+ items).
  mediaUrlsJson String?

  shareCount Int @default(0)

  /// When set, identifies an idempotent demo/QA seed row (`syncFitHubDemoSeedPosts` in `lib/client-fithub-sample-posts.ts`).
  demoSeedKey String? @unique

  /// Internal QA trainer FitHub posts that must never appear in public/client feeds (author-only sandbox).
  internalQaSandboxPost Boolean @default(false)

  likes           TrainerFitHubPostLike[]
  comments        TrainerFitHubComment[]
  reposts         ClientFitHubRepost[]
  contentReports  TrainerFitHubPostReport[]
  clientShares    ClientFitHubPostShare[]
  promotions      TrainerFitHubPostPromotion[]

  @@index([trainerId, createdAt])
  @@map("trainer_fit_hub_posts")
  @@schema("public")
}

/// One recorded share per client per post (idempotent share action; `shareCount` stays in sync in API).
model ClientFitHubPostShare {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   TrainerFitHubPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([postId, clientId])
  @@index([clientId])
  @@map("client_fit_hub_post_shares")
  @@schema("public")
}

/// Client-reported FitHub post for trust & safety review (does not auto-suspend accounts).
model TrainerFitHubPostReport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   TrainerFitHubPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  /// Values from `FITHUB_CONTENT_REPORT_CATEGORIES` (`lib/fithub-content-report-categories.ts`).
  category String
  details  String?

  /// PENDING | REVIEWED | DISMISSED
  status String @default("PENDING")

  @@unique([postId, clientId])
  @@index([status, createdAt])
  @@map("trainer_fit_hub_post_reports")
  @@schema("public")
}

model TrainerFitHubPostLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   TrainerFitHubPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([postId, clientId])
  @@index([clientId])
  @@map("trainer_fit_hub_post_likes")
  @@schema("public")
}

model TrainerFitHubComment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   TrainerFitHubPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  body String

  @@index([postId, createdAt])
  @@map("trainer_fit_hub_comments")
  @@schema("public")
}

model ClientFitHubRepost {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   TrainerFitHubPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([postId, clientId])
  @@index([clientId])
  @@map("client_fit_hub_reposts")
  @@schema("public")
}

/// In-app notification feed for trainers (inquiries, chats, compliance, billing, platform).
model TrainerNotification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  /// INQUIRY | CHAT | COMPLIANCE | CERTIFICATION | BILLING | PLATFORM
  kind     String
  title    String
  body     String
  linkHref String?
  readAt   DateTime?

  @@index([trainerId, createdAt])
  @@map("trainer_notifications")
  @@schema("public")
}

/// Client saved a trainer from browse (e.g. swipe right) for quick access and chats list.
model ClientSavedTrainer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId  String
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  /// Client interest on trainer profile: PENDING_TRAINER (awaiting coach) | ACCEPTED | DECLINED. Default ACCEPTED preserves legacy saves.
  trainerInquiryStatus String @default("ACCEPTED")

  @@unique([clientId, trainerId])
  @@index([clientId])
  @@index([trainerId, trainerInquiryStatus])
  @@map("client_saved_trainers")
  @@schema("public")
}

/// Client dismissed a coach in the swipe deck (left swipe). Hidden from swipe only; scroll still lists until matched.
model ClientTrainerBrowsePass {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  clientId  String
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  /// When the client last passed this coach; drives 90-day exclusion from the “new” deck (`createdAt` if null).
  lastPassedAt DateTime?

  @@unique([clientId, trainerId])
  @@index([clientId])
  @@map("client_trainer_browse_passes")
  @@schema("public")
}

/// Trainer dismissed / unmatched this client in discovery (90-day exclusion, mirrors `ClientTrainerBrowsePass`).
model TrainerClientBrowsePass {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  /// When the coach last passed or unmatched this client (`createdAt` if null).
  lastPassedAt DateTime?

  @@unique([trainerId, clientId])
  @@index([trainerId])
  @@index([clientId])
  @@map("trainer_client_browse_passes")
  @@schema("public")
}

/// Verified destinations for trainer sign-in 2FA (mirrors `ClientTwoFactorChannel`).
model TrainerTwoFactorChannel {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  delivery String
  email    String?
  phone    String?

  verified Boolean @default(false)

  verifyOtpHash    String?
  verifyOtpExpires DateTime?

  lastCode    String?
  expiresAt   DateTime?

  /// Set when the user taps “Resend code” (login initial send clears this). Used only for the 60s resend throttle.
  lastEmailResendAt DateTime?

  isDefaultLogin Boolean @default(false)

  @@index([trainerId])
  @@map("trainer_two_factor_channels")
  @@schema("public")
}

model TrainerProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainerId String @unique
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  hasSignedTOS           Boolean @default(false)
  hasUploadedW9          Boolean @default(false)
  hasPaidBackgroundFee   Boolean @default(false)
  /// Vendor pipeline: NOT_STARTED | PENDING | APPROVED | NEEDS_FURTHER_REVIEW | DENIED
  backgroundCheckStatus String @default("NOT_STARTED")

  /// Relative URL under `public/` (e.g. `/uploads/trainers/...`).
  certificationUrl String?
  /// Additional certs (PDF/image), optional.
  otherCertificationUrl String?
  /// Optional additional cert — NOT_STARTED | PENDING | APPROVED | DENIED (does not block onboarding).
  otherCertificationReviewStatus String @default("NOT_STARTED")
  /// CPT verification: NOT_STARTED | PENDING | APPROVED | DENIED
  certificationReviewStatus String @default("NOT_STARTED")
  /// Nutritionist / nutrition credential file (PDF/image).
  nutritionistCertificationUrl String?
  /// Same status enum as CPT: NOT_STARTED | PENDING | APPROVED | DENIED
  nutritionistCertificationReviewStatus String @default("NOT_STARTED")

  /// Onboarding step: which professional paths the trainer selected (drives required uploads).
  onboardingTrackCpt        Boolean @default(false)
  onboardingTrackNutrition Boolean @default(false)
  /// Mutually exclusive with CPT for catalog: CSCS / CES / accredited group fitness (see `trainer-specialist-roles.ts`).
  onboardingTrackSpecialist Boolean @default(false)
  /// When specialist track is on: slug from `SPECIALIST_ROLE_IDS`.
  specialistProfessionalRole String?
  specialistCertificationUrl String?
  specialistCertificationReviewStatus String @default("NOT_STARTED")

  /// Legacy parallel field; keep in sync with vendor status where applicable.
  backgroundCheckReviewStatus String @default("NOT_STARTED")

  /// JSON string of W-9 answers until a formal e-sign flow exists.
  w9Json String?

  /// Proof-of-email OTP before sending a W-9 copy to the trainer account email (hashed; cleared after use).
  w9SelfServeEmailOtpHash    String?
  w9SelfServeEmailOtpExpires DateTime?

  /// When background screening last returned APPROVED (drives 12-month renewal cycle).
  backgroundCheckClearedAt DateTime?
  /// Set when we notify the trainer that renewal is due within ~30 days.
  backgroundCheckExpiryWarningSentAt DateTime?

  /// Set when the trainer completes the skeleton background-check step; marks the compliance profile as ready for the main dashboard.
  dashboardActivatedAt DateTime?
  /// not_started | in_progress | completed — Onboarding Questionnaire (trainer Daily Questionnaires).
  matchQuestionnaireStatus String @default("not_started")
  /// Structured answers for search + AI matching (JSON string; SQLite has no Prisma Json type here).
  matchQuestionnaireAnswers     String?
  matchQuestionnaireCompletedAt DateTime?
  /// Optional questionnaire completions (JSON array), excluding mandatory Onboarding Questionnaire.
  followUpQuestionnaireAnswersJson String?
  /// Plain-text profile for search + AI when pairing trainers with clients; regenerated on each Onboarding Questionnaire submit.
  aiMatchProfileText String?

  /// Published services & pricing (JSON). Managed only from the trainer dashboard—not the Onboarding Questionnaire.
  serviceOfferingsJson String?

  /// When false, clients see services on the profile but checkout links are withheld (arrange purchase after you connect).
  clientsCanPurchaseServicesFromProfile Boolean @default(true)

  /// When set, trainer completed Premium Page signup and can use Premium Hub (social-style creator tools).
  premiumStudioEnabledAt DateTime?
  /// Last time the trainer opened FitHub studio activity in Premium (unread counts vs main notification digest).
  fitHubStudioActivitySeenAt DateTime?
  /// JSON string array of studio activity item ids marked read individually (`like-*`, `comment-*`, `repost-*`, `share-*`).
  fitHubStudioActivityReadKeysJson String?

  /// JSON: guidelines text, weekly windows, specific slots (see `lib/booking-availability.ts`).
  bookingAvailabilityJson String?
  /// IANA zone for interpreting availability (display + booking copy).
  bookingTimezone String @default("America/New_York")
  /// When true, paying clients may complete self-service booking from the trainer’s public profile (in addition to chat invites).
  clientPublicSelfBookingEnabled Boolean @default(false)

  /// JSON: default virtual meeting length, preferred sync platform, etc. (see `lib/trainer-virtual-meeting-settings.ts`).
  virtualMeetingSettingsJson String?

  /// Consecutive booked sessions where the trainer failed the SESSION STARTED punch-in policy (see Terms).
  consecutiveMissedSessionPunches Int @default(0)

  /// JSON string array (max 4) of `TrainerDashboardQuickLinkId` keys for the trainer home Quick Links card.
  dashboardQuickLinkIdsJson String?

  @@map("trainer_profiles")
  @@schema("public")
}

/// One row per trainer–client pair for on-platform messaging.
model TrainerClientConversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainerId String
  trainer   Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  /// POTENTIAL_CLIENT | LEAD | FIRST_TIME_CLIENT | REGULAR_CLIENT | FORMER_CLIENT
  relationshipStage String @default("POTENTIAL_CLIENT")

  /// Chat is live for both sides (e.g. inquiry accepted, or trainer-initiated nudge).
  officialChatStartedAt DateTime?

  /// When one party archived / unmatched; thread moves out of active inbox until revived or purged.
  archivedAt        DateTime?
  /// Auto-delete archived row after this instant (typically `archivedAt` + 90 days).
  archiveExpiresAt  DateTime?
  /// CLIENT | TRAINER — who chose delete/unmatch; only they may revive within the archive window.
  unmatchInitiatedBy String?

  /// Session credits from paid packages (per_session / multi_session / per_hour); DIY + monthly set unlimited flag instead.
  sessionCreditsPurchased Int @default(0)
  sessionCreditsUsed      Int @default(0)
  /// When true (DIY or monthly-style purchase), booking does not consume session credits.
  bookingUnlimitedAfterPurchase Boolean @default(false)

  /// After trainer declines a client-initiated reschedule, client must purchase again before new invites (per policy).
  blockFreeSessionBookingUntilRepurchase Boolean @default(false)

  messages               TrainerClientChatMessage[]
  chatAdminReviewItems   ChatAdminReviewItem[]
  bookedTrainingSessions BookedTrainingSession[]
  packageCancellationRequests TrainerPackageCancellationRequest[]

  internalQaDeferredOfficialChat InternalQaDeferredOfficialChat?

  @@unique([trainerId, clientId])
  @@index([trainerId, updatedAt])
  @@index([clientId, updatedAt])
  @@index([archiveExpiresAt])
  @@map("trainer_client_conversations")
  @@schema("public")
}

