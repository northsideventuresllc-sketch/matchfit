/// Booked mobile/virtual session awaiting client confirmation (24h auto-complete when implemented).
model BookedTrainingSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainerId String
  trainer   Trainer @relation("BookedSessionTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client @relation("BookedSessionClient", fields: [clientId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   TrainerClientConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  scheduledStartAt       DateTime
  scheduledEndAt         DateTime?
  confirmationDeadlineAt DateTime

  /// PENDING_CONFIRMATION | INVITED | AUTO_COMPLETED | CLIENT_DISPUTED | CLIENT_CONFIRMED | CANCELLED
  status String @default("PENDING_CONFIRMATION")

  trainerAmountCents Int @default(0)

  inviteNote String?

  sourceServiceTransactionId String?
  sourceServiceTransaction   TrainerClientServiceTransaction? @relation("BookingFromServiceTx", fields: [sourceServiceTransactionId], references: [id], onDelete: SetNull)

  /// IN_PERSON | VIRTUAL
  sessionDelivery String @default("IN_PERSON")

  /// HTTPS join link for virtual sessions (manual paste or created via trainer’s linked Zoom / Meet / Teams).
  videoConferenceJoinUrl     String?
  /// MANUAL | GOOGLE_MEET | ZOOM | MICROSOFT_TEAMS
  videoConferenceProvider    String?
  videoConferenceExternalId  String?
  videoConferenceSyncedAt    DateTime?

  /// NONE | SCHEDULED | CHECK_IN_ACTIVE | AWAITING_CLIENT_FOLLOWUP | COMPLETED_LOCKED | AUTO_COMPLETED | CANCELLED_FOREGONE | CANCELLED_RESCHED_DECLINED_BY_CLIENT | CANCELLED_RESCHED_DECLINED_BY_TRAINER | CANCELLED_TRAINER_SUSPENDED | …
  fulfillmentStatus String @default("NONE")

  /// Net service-pool amount for this session after platform + processing fees (per ledger ÷ units × consumption).
  allocatedCoachServiceCents Int @default(0)

  markedCompleteAt   DateTime?
  markedNotCompleteAt DateTime?
  sessionClosedAt    DateTime?
  lastStripeRefundId String?
  lastStripeRefundCents Int?

  /// Stripe PI to use for prorated refunds tied to this seat (set when the client confirms the invite).
  attributionStripePaymentIntentId String?

  rescheduleRequests SessionRescheduleRequest[]
  payoutDisputes     SessionPayoutDispute[]

  /// Client Gate A closed (confirm, auto-silence, or revoke handled separately).
  gateASatisfiedAt DateTime?
  /// CLIENT_CONFIRM | AUTO_SILENCE
  gateASource          String?
  gateARevokedBeforeStartAt DateTime?

  /// Trainer Gate B — manual only; payout stays on file until set.
  trainerGateBCompletedAt DateTime?

  /// Starts after BOTH gates close: max(gate A, gate B) + 48h dispute buffer.
  payoutBufferEndsAt DateTime?
  payoutFundsFrozen  Boolean @default(false)

  /// Billing units consumed by this session (1 for per-session; fractional hours for per_hour).
  sessionConsumedUnits Float @default(1)

  /// Net add-on ledger slice attributed to this booking (see transaction ledger).
  allocatedNetAddonCents Int @default(0)

  disputeOpenedAt DateTime?

  /// Set when marketplace cron evaluated punch-in compliance for this session (idempotent miss counter).
  punchMissEvaluatedAt DateTime?

  punchIns SessionTrainerPunchIn[]
  trainerBusinessMileageEntries TrainerBusinessMileageEntry[]

  @@index([status, confirmationDeadlineAt])
  @@index([trainerId, clientId])
  @@index([trainerId, scheduledStartAt])
  @@index([conversationId])
  @@map("booked_training_sessions")
  @@schema("public")
}

