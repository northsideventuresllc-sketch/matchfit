# PostgreSQL — pooled URL for the running app (Supabase: port 6543, `?pgbouncer=true&sslmode=require`).
# Encode reserved characters in the password (e.g. ! → %21).
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
#
# Direct URL for `prisma migrate` / `db push` only (Supabase: host db.PROJECT_REF.supabase.co:5432, user `postgres`).
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Required for sessions and one-time codes (min 32 characters)
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Optional: set to 0 only when running `next start` (NODE_ENV=production) on plain http://localhost — otherwise Secure cookies never stick.
# Never disable on a public HTTPS deployment.
# MATCH_FIT_COOKIE_SECURE=0

# Cloudflare Turnstile — bot protection on sign-up and every sign-in (including 2FA completion).
# Dashboard: https://dash.cloudflare.com/ → Turnstile → add site → prefer "Managed" mode.
# Production: set both. Development: omit both to skip verification, or use Cloudflare dummy pass keys from their docs.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Optional: OpenAI for richer trainer service price-check copy (dashboard “Review pricing”). Without a key, benchmarks only.
# OPENAI_API_KEY=
# OPENAI_PRICE_MODEL=gpt-4o-mini
# Optional: model for chat ToS/Privacy compliance review (same OPENAI_API_KEY). Defaults to gpt-4o-mini when unset.
# OPENAI_CHAT_COMPLIANCE_MODEL=gpt-4o-mini

# Optional: Match Fit ops — POST /api/internal/safety/lift with header `x-matchfit-internal-secret`
# MATCHFIT_INTERNAL_TOOLS_SECRET=

# Optional: POST /api/cron/match-fit-tos-jobs with Authorization: Bearer <secret> (background-check renewal, session auto-complete, DIY alerts)
# CRON_SECRET=

# Optional: GET /api/admin/chat-review-queue with Authorization: Bearer <secret> (chat leakage flags)
# MATCHFIT_ADMIN_API_SECRET=

# Optional: email codes via Resend (https://resend.com). OTP mail sends From onboarding@resend.dev.
# In NODE_ENV=development, all Resend "To" addresses are redirected to RESEND_DEV_INBOX (defaults to support@match-fit.net in src/lib/resend-client.ts).
# RESEND_API_KEY=
# Optional verified-domain From (defaults to onboarding@resend.dev). Used for login 2FA email codes.
# RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional: Supabase Auth (PKCE email confirmation). Add Site URL + Redirect URLs in Supabase dashboard (include https://match-fit.net/auth/callback and local http://localhost:3000/auth/callback when developing).
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: override default https://match-fit.net/auth/callback (used as signUp emailRedirectTo and OAuth redirect).
# NEXT_PUBLIC_SUPABASE_EMAIL_CALLBACK_URL=https://match-fit.net/auth/callback

# Optional: POST /api/welcome-email (or /api/internal/welcome-email) with Authorization: Bearer <secret> — sends new-user welcome (Resend SDK). Production From: Match Fit <support@match-fit.net> (domain must be verified in Resend).
# MATCHFIT_WELCOME_EMAIL_SECRET=

# Optional: POST /api/internal/transactional-email-samples in production — Authorization: Bearer <secret> sends one sample of each transactional template to RESEND_DEV_INBOX. In development, no secret is required.
# RESEND_DEV_INBOX=support@match-fit.net
# MATCHFIT_TRANSACTIONAL_EMAIL_SAMPLES_SECRET=

# Optional: POST /api/welcome-email (or /api/internal/welcome-email) with Authorization: Bearer <secret> — sends new-user welcome (Resend SDK). Production From: Match Fit <support@match-fit.net> (domain must be verified in Resend).
# MATCHFIT_WELCOME_EMAIL_SECRET=

# One-time: bootstrap staff login `jobo0602` after running prisma migrations (see scripts/seed-bootstrap-admin.js).
# MATCH_FIT_BOOTSTRAP_ADMIN_PASSWORD=

# Web Push (VAPID) — free browser lock-screen notifications. Generate keys: `npx web-push generate-vapid-keys`
# NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_CONTACT_EMAIL=ops@yourdomain.com

# Integration tests (`src/__tests__/login-2fa.integration.test.ts`) run `prisma db push` before the suite. If Prisma refuses
# because a migration would drop data, set this to 1 only when DATABASE_URL points at a disposable database — never production.
# MATCH_FIT_INTEGRATION_TEST_DB_PUSH_ACCEPT_DATA_LOSS=1

# Optional: 32-byte AES key (base64) for encrypting OAuth refresh tokens at rest (Google Meet / Zoom / Teams). If unset, a dev key is derived from AUTH_SECRET (set explicitly in production).
# MATCHFIT_TOKEN_ENCRYPTION_KEY=

# Optional: trainer video OAuth (redirect URIs: {NEXT_PUBLIC_APP_URL}/api/trainer/oauth/<google|zoom|microsoft>/callback)
# Google Cloud Console → OAuth client: add authorized redirect URI exactly as above for "google".
# Scopes (see GOOGLE_TRAINER_VIDEO_OAUTH_SCOPES in src/lib/trainer-video-oauth-tokens.ts): calendar.events + meetings.space.created; authorize uses access_type=offline for refresh tokens.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# ZOOM_OAUTH_CLIENT_ID=   # Same Zoom OAuth app as in Supabase — required for token refresh / meeting API after Supabase link
# ZOOM_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=   # Azure portal "Value" of the client secret (not the secret id)
# MICROSOFT_OAUTH_TENANT_ID=       # Optional Entra tenant UUID; when set, authorize/token use this tenant instead of "common"
# Supabase (Authentication → Providers → Azure): same Azure app id/secret; add the Microsoft callback URL to Supabase redirect URLs and Azure redirect URIs as required by your setup.
# Supabase (Authentication → Providers → Zoom): add Zoom client id/secret from Zoom Marketplace; allow list Supabase Auth callback on Zoom. Add this app’s /api/trainer/oauth/zoom/callback to Supabase redirect URLs.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Public site URL for Stripe Checkout return URLs (falls back to request origin if unset)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Trainer onboarding: background check list price (USD, ex tax) shown at checkout and credited toward $100 registration
# NEXT_PUBLIC_TRAINER_BACKGROUND_CHECK_FEE_USD="49"

# Checkr background screening (https://dashboard.checkr.com)
# CHECKR_API_KEY=
# CHECKR_WEBHOOK_SECRET=
# CHECKR_PACKAGE_SLUG="tasker_standard"
# Webhook endpoint: /api/webhooks/checkr
# MATCH_FIT_BACKGROUND_CHECK_REVIEW_INBOX="jb@match-fit.net"

# Supabase service role — stores Checkr candidate/report ids (see supabase/migrations/20260519120000_trainer_checkr_vault.sql)
# SUPABASE_SERVICE_ROLE_KEY=

# Launch cohort: comma-separated emails that never consume first-50 client / first-10 trainer slots (in addition to internal QA)
# MATCH_FIT_LAUNCH_COHORT_EXCLUDED_EMAILS=

# Stripe (required for subscription checkout — use test keys in development)
# https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=
# Optional if you only use hosted Checkout (no Payment Element on your site)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Recurring Price ID for $10/month (Products → create price, recurring monthly)
# STRIPE_PRICE_ID=price_...
# Webhook signing secret (https://dashboard.stripe.com/webhooks) — endpoint: /api/webhooks/stripe
# STRIPE_WEBHOOK_SECRET=

# Launch promos (server-side): first 50 clients = 14-day trial + card required; after cap = 3-day trial or pay now.
# MATCH_FIT_CLIENT_FOUNDING_TRIAL_MAX_CLIENTS=50
# MATCH_FIT_CLIENT_FOUNDING_TRIAL_DAYS=14
# MATCH_FIT_CLIENT_POST_CAP_TRIAL_DAYS=3
# First 10 trainers: platform registration = 20% of Checkr BG fee; after cap = $100 minus BG (cents on profile).
# MATCH_FIT_TRAINER_FOUNDING_BG_PERCENT_MAX=10
# Default Checkr BG mock/webhook amount in cents when vendor price is missing locally.
# MATCH_FIT_CHECKR_DEFAULT_BG_FEE_CENTS=4900
# Checkr webhook: POST https://<your-domain>/api/webhooks/checkr — set secret in Checkr Dashboard → Developer Settings.
# Signs raw body with HMAC-SHA256 in X-Checkr-Signature (hex). Required in production.
# CHECKR_WEBHOOK_SECRET=
# CHECKR_API_KEY=  (when Checkr API is ready — create candidates / invitations from onboarding)

# Dev-only (NODE_ENV=development): Mac shortcuts Command+Option+Shift+C (client) / Command+Option+Shift+T (trainer) jump into fixed test accounts.
# Use the same value you would type at sign-in: email, username, or phone.
# MATCH_FIT_DEV_CLIENT_IDENTIFIER=
# MATCH_FIT_DEV_TRAINER_IDENTIFIER=

# Development only: comma-separated trainer usernames that automatically receive APPROVED CPT + nutrition credentials,
# both onboarding tracks, and placeholder cert URLs under public/dev/ (see `src/lib/trainer-dev-test-cert-sync.ts`).
# The dev shortcut trainer (MATCH_FIT_DEV_TRAINER_IDENTIFIER) is included when its username, email, or phone matches.
# MATCH_FIT_TEST_TRAINER_USERNAMES=

# Development only: when true/1/yes, every trainer session receives the same auto-approved CPT + nutrition setup as above
# (useful when you have multiple local trainer accounts and do not want to list every username).
# MATCH_FIT_DEV_APPROVE_ALL_TRAINER_CERTS=

# Development only: trainer onboarding bypass password (local only — never set in production).
# MATCH_FIT_TRAINER_ONBOARDING_DEV_PASSWORD=

# Internal QA / owner sandbox (comma-separated emails). Requires MATCH_FIT_INTERNAL_QA_ENABLED=1.
# Enables: password-based trainer onboarding bypasses (account password), client subscribe wall bypass,
# synthetic trainer/client match simulation (America/New_York daily reset), promo token wallet credits without Stripe,
# FitHub posts flagged internalQaSandboxPost (hidden from all public/client feeds), homepage user counts exclude these emails + synthetics.
# MATCH_FIT_INTERNAL_QA_ENABLED=1
# MATCH_FIT_INTERNAL_QA_CLIENT_EMAILS=owner-client@example.com
# MATCH_FIT_INTERNAL_QA_TRAINER_EMAILS=owner-trainer@example.com
#
# Seed script: scripts/seed-match-fit-internal-qa-accounts.ts (see file header for required MATCH_FIT_INTERNAL_QA_SEED_* vars).

# Development only: comma-separated trainer usernames used for idempotent FitHub demo posts (see `lib/client-fithub-sample-posts.ts`).
# If unset, demo posts are assigned to the earliest-created trainers in the database.
# MATCH_FIT_FITHUB_DEMO_TRAINER_USERNAMES=

# --- Atlanta public beta caps & waitlist (set MATCH_FIT_BETA_GATES_ENABLED=1 in production beta) ---
# MATCH_FIT_BETA_GATES_ENABLED=1
# MATCH_FIT_BETA_MAX_TRAINERS=10
# MATCH_FIT_BETA_MAX_CLIENTS=50
# Comma-separated emails excluded from cap counts (test / staff accounts).
# MATCH_FIT_BETA_EXCLUDE_CAP_COUNT_EMAILS=you+test@example.com
# Optional: extra 5-digit ZIPs allowed beyond the built-in Atlanta metro list.
# MATCH_FIT_BETA_EXTRA_SERVICE_ZIPS=30094,30189
# Days an invited waitlist user has to finish signup (default 30). Cron fills slots every 15 min via vercel.json.
# MATCH_FIT_BETA_INVITE_SLOT_DAYS=30
# CRON_SECRET=  (Bearer token for GET/POST /api/cron/match-fit-tos-jobs — Vercel Cron uses GET; also runs beta waitlist promotion)
#
# --- Quick local beta setup (generates .env + secrets file) ---
# npm run beta:setup
# Then add Stripe + Resend keys to .env, copy secrets to Vercel Production, redeploy:
# npm run beta:preflight
# npm run beta:vercel-env   (requires: npx vercel link)
